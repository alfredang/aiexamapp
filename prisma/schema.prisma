generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========== Enums ===========

enum Role {
  USER
  ADMIN
}

enum QType {
  SINGLE
  MULTI
  TRUE_FALSE
  ORDERING
  HOTSPOT
}

enum QStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Tier {
  PRACTICE
  BUNDLE
  VOUCHER
  ADMIN_GRANT
}

enum Mode {
  PRACTICE
  EXAM
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYPAL
  PAYNOW
  HITPAY
  TEST
}

enum DeliveryStatus {
  SCHEDULED
  PROCESSING
  SENT
  FAILED
  CANCELED
}

enum EmailTemplateKey {
  ORDER_CONFIRMATION
  VOUCHER_DELIVERY
  OTP_LOGIN
  OTP_REGISTER
  OTP_RESET
  OTP_TEASER_GATE
  PASSWORD_RESET
}

// =========== Models ===========

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          Role      @default(USER)
  active        Boolean   @default(true)
  nationality   String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  attempts      Attempt[]
  entitlements  Entitlement[]
  orders        Order[]
  adminLogs     AdminLog[]
  billingAddresses BillingAddress[]
}

model Vendor {
  id    String  @id @default(cuid())
  slug  String  @unique
  name  String
  logo  String?
  description String?
  exams Exam[]
}

model Exam {
  id              String     @id @default(cuid())
  vendorId        String
  vendor          Vendor     @relation(fields: [vendorId], references: [id])
  code            String
  slug            String     @unique
  title           String
  description     String
  level           String     // Foundational | Associate | Professional | Specialty
  durationMinutes Int
  passingScore    Int
  questionCount   Int        // questions per practice exam attempt
  domains         Json       // [{name: string, weight: number}]
  pricePractice   Int        // cents
  priceBundle     Int
  priceVoucher    Int
  published       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  questions       Question[]
  attempts        Attempt[]
  entitlements    Entitlement[]
  orders          Order[]
  bundleItems     BundleItem[]
  @@index([vendorId])
}

// A curated multi-exam product. Distinct from the existing per-exam
// `BUNDLE` Tier (which packages PRACTICE + VOUCHER for a single exam).
// A Bundle can contain entitlements across multiple exams — e.g. two
// practice tiers + one voucher across two different certifications.
model Bundle {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  description  String
  price        Int          // PRACTICE tier price (cents)
  priceVoucher Int?         // VOUCHER tier price (cents) — set when the bundle
                            // offers a Voucher upgrade (real exam voucher +
                            // practice access). null = practice-only bundle.
  published    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  items        BundleItem[]
  orders       Order[]
}

// One line item inside a Bundle: which exam, at which tier (PRACTICE
// or VOUCHER). When a Bundle is purchased, fulfillOrder writes one
// Entitlement per BundleItem.
model BundleItem {
  id       String @id @default(cuid())
  bundleId String
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  examId   String
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  tier     Tier   // PRACTICE or VOUCHER (others not meaningful in a bundle)
  position Int    @default(0)
  @@unique([bundleId, examId, tier])
  @@index([examId])
}

model Question {
  id          String    @id @default(cuid())
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  domain      String
  difficulty  Int       @default(3) // 1-5
  type        QType     @default(SINGLE)
  stem        String
  options     Json      // [{id: string, text: string}]
  correct     Json      // string[] of option ids (for HOTSPOT/ORDERING this is type-specific)
  explanation String
  references  Json?     // [{label: string, url: string}]
  status      QStatus   @default(DRAFT)
  generatedBy String?   // "manual" | model id
  isTeaser    Boolean   @default(false)
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([examId, status])
  @@index([examId, isTeaser])
}

model Entitlement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  tier      Tier
  voucher   String?  @unique
  grantedAt DateTime @default(now())
  expiresAt DateTime?
  delivery  VoucherDelivery?
  @@unique([userId, examId, tier])
  @@index([userId])
}

model Attempt {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestToken  String?
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id])
  mode        Mode
  isTeaser    Boolean   @default(false)
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  expiresAt   DateTime?
  durationSec Int       @default(0)
  score       Float?
  passed      Boolean?
  questionIds String[]
  // responses: Record<questionId, { answer: string[]; flagged?: boolean; timeSpent?: number }>
  responses   Json      @default("{}")
  lastSavedAt DateTime  @default(now())
  @@index([userId, examId])
  @@index([guestToken])
}

// An order is for EITHER a single Exam at a tier, OR a Bundle.
// Exactly one of (examId+tier) and bundleId should be set, enforced by
// application logic in the create-order route. Both fields are nullable
// in the schema so we can model both purchase types without a separate
// table.
model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  examId          String?
  exam            Exam?       @relation(fields: [examId], references: [id])
  tier            Tier?
  bundleId        String?
  bundle          Bundle?     @relation(fields: [bundleId], references: [id])
  // Legacy PayPal-specific columns. Retained in Phase 0 for back-compat;
  // new code reads/writes the provider* columns below. A later migration
  // will drop these once PayPal paths are switched over.
  paypalOrderId   String?     @unique
  paypalCaptureId String?     @unique
  paypalPayload   Json?
  // Provider-agnostic identifiers.
  provider          PaymentProvider @default(PAYPAL)
  providerOrderId   String?
  providerCaptureId String?
  providerPayload   Json?
  billingAddressId  String?
  billingAddress    BillingAddress? @relation(fields: [billingAddressId], references: [id])
  refundedAt        DateTime?
  refundAmount      Int?
  refundReason      String?
  refundRef         String?
  amount          Int         // cents
  currency        String      @default("USD")
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  capturedAt      DateTime?
  @@unique([provider, providerOrderId])
  @@unique([provider, providerCaptureId])
  @@index([userId, status])
  @@index([status, createdAt])
}

model BillingAddress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName   String
  company    String?
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String   // ISO-2
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
  @@index([userId])
}

model VoucherDelivery {
  id            String         @id @default(cuid())
  entitlementId String         @unique
  entitlement   Entitlement    @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  orderId       String?
  scheduledFor  DateTime
  status        DeliveryStatus @default(SCHEDULED)
  attempts      Int            @default(0)
  lastError     String?
  sentAt        DateTime?
  voucherCode   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@index([status, scheduledFor])
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  bodyHtml    String
  excerpt     String?
  published   Boolean  @default(true)
  showInFooter Boolean @default(false)
  footerGroup String?  // "legal" | "company" — drives footer column placement
  position    Int      @default(0)
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  @@index([showInFooter, footerGroup, position])
}

model EmailTemplate {
  id          String           @id @default(cuid())
  key         EmailTemplateKey @unique
  subject     String
  bodyHtml    String
  bodyMjml    String?
  enabled     Boolean          @default(true)
  updatedById String?
  updatedAt   DateTime         @updatedAt
  createdAt   DateTime         @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  purpose   String   // "LOGIN" | "REGISTER" | "RESET" | "TEASER_GATE"
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([email, purpose])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  @@index([adminId, createdAt])
}
